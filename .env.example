# Secure Agentic IT Support Copilot local environment example.
# Copy to .env for local development. Do not commit .env.

ITSC_ENV=local
ITSC_LOG_LEVEL=INFO
ITSC_EXECUTION_ENABLED=false
ITSC_VECTOR_STORE=local
ITSC_SQLITE_PATH=data/app.sqlite3

# The deterministic local MVP does not require an LLM provider key.
# Future provider adapters should read keys from local environment or a secret manager.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
